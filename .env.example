# RepoQuest AI Assistant Configuration
# Copy this file to .env and fill in your values

# Claude API Key (optional)
# Get your key from: https://console.anthropic.com/
CLAUDE_API_KEY=

# Claude Model (optional, defaults to claude-sonnet-4-20250514)
CLAUDE_MODEL=claude-sonnet-4-20250514

# Enable AI Assistant Mode (optional, defaults to false)
# Set to "true" to enable AI features
REPOQUEST_AI_ENABLED=false
