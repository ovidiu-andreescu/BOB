# RepoQuest AI Assistant Configuration
# Copy this file to .env and fill in your values

# Claude API Key (optional)
# Get your key from: https://console.anthropic.com/
CLAUDE_API_KEY=

# Claude Model (optional, defaults to claude-sonnet-4-20250514)
CLAUDE_MODEL=claude-sonnet-4-20250514

# Enable AI Assistant Mode (optional, defaults to false)
# Set to "true" to enable AI features
REPOQUEST_AI_ENABLED=false

# Optional async assistant service.
# Leave empty to call the configured provider from the Streamlit process.
# In Docker Compose assistant mode, set this in the app container:
# REPOQUEST_ASSISTANT_SERVICE_URL=http://assistant:8765
REPOQUEST_ASSISTANT_SERVICE_URL=
REPOQUEST_ASSISTANT_SERVICE_TIMEOUT_SECONDS=45

# Optional service-only provider override for local testing.
# Set to "mock" to exercise the async service without network calls.
REPOQUEST_ASSISTANT_SERVICE_PROVIDER=

# Local Model Configuration (optional)
# Use when running with a local model server (Ollama, LM Studio, llama.cpp, etc.)
# Set REPOQUEST_ASSISTANT_PROVIDER=local to enable local model mode
REPOQUEST_ASSISTANT_PROVIDER=

# Local model server base URL (OpenAI-compatible endpoint)
# Examples:
#   Ollama: http://localhost:11434/v1
#   LM Studio: http://localhost:1234/v1
#   llama.cpp: http://localhost:8080/v1
REPOQUEST_LOCAL_MODEL_BASE_URL=

# Local model name
# Examples:
#   Ollama: llama3.1, codellama, mistral
#   LM Studio: model name from UI
#   llama.cpp: model file name
REPOQUEST_LOCAL_MODEL_NAME=

# Deployment Profiles
# ====================
# RepoQuest supports multiple deployment profiles:
#
# 1. Deterministic Code Assistant (default)
#    - No AI, no secrets required
#    - REPOQUEST_AI_ENABLED=false (or unset)
#
# 2. Mock AI Assistant (testing)
#    - REPOQUEST_AI_ENABLED=true
#    - REPOQUEST_ASSISTANT_PROVIDER=mock
#
# 3. Cloud AI Assistant (Claude)
#    - REPOQUEST_AI_ENABLED=true
#    - CLAUDE_API_KEY=your_key_here
#    - REPOQUEST_ASSISTANT_PROVIDER=claude (or unset)
#
# 4. Local Model Assistant
#    - REPOQUEST_AI_ENABLED=true
#    - REPOQUEST_ASSISTANT_PROVIDER=local
#    - REPOQUEST_LOCAL_MODEL_BASE_URL=http://localhost:11434/v1
#    - REPOQUEST_LOCAL_MODEL_NAME=llama3.1
#
# 5. Async Assistant Service
#    - REPOQUEST_AI_ENABLED=true
#    - REPOQUEST_ASSISTANT_SERVICE_URL=http://assistant:8765
#    - REPOQUEST_ASSISTANT_SERVICE_PROVIDER=mock|claude|local (in service container)
